import { NextRequest, NextResponse } from "next/server";
import { extractBearerToken, verifyMobileToken } from "@/lib/mobile-auth";
import { prisma } from "@/lib/prisma";

function timeAgo(dateInput: Date | string | null | undefined) {
  if (!dateInput) return null;
  const date = new Date(dateInput);
  const diffMs = Date.now() - date.getTime();

  const minute = 60_000;
  const hour = 60 * minute;
  const day = 24 * hour;
  const month = 30 * day;

  if (diffMs < hour) return `${Math.max(1, Math.floor(diffMs / minute))}m ago`;
  if (diffMs < day) return `${Math.floor(diffMs / hour)}h ago`;
  if (diffMs < month) return `${Math.floor(diffMs / day)}d ago`;
  return `${Math.floor(diffMs / month)}mo ago`;
}

async function getDashboardUpdatesSafe() {
  try {
    const items = await (prisma as any).announcement.findMany({
      where: {
        OR: [{ published: true }, { isPublished: true }],
      },
      orderBy: {
        publishedAt: "desc",
      },
      take: 5,
      select: {
        id: true,
        title: true,
        message: true,
        publishedAt: true,
      },
    });

    return items.map((item: any) => ({
      id: item.id,
      title: item.title,
      message: item.message,
      priority: "info",
      postedBy: "Department",
      createdAt: timeAgo(item.publishedAt),
    }));
  } catch {
    return [
      {
        id: "dashboard-fallback-1",
        title: "New member orientation scheduled",
        message:
          "Interested in joining? Come meet the officers, tour the station, and learn what to expect.",
        priority: "info",
        postedBy: "Department",
        createdAt: "3mo ago",
      },
      {
        id: "dashboard-fallback-2",
        title: "Winter safety reminder: heating and CO alarms",
        message:
          "Check your smoke/CO alarms and keep space heaters clear. Replace batteries and test monthly.",
        priority: "info",
        postedBy: "Department",
        createdAt: "3mo ago",
      },
    ];
  }
}

async function getTrainingStatsSafe(userId: string) {
  const stats = {
    assignedTrainingCount: 0,
    completedTrainingCount: 0,
    pendingJprReviews: 0,
    pendingDocumentSignatures: 0,
  };

  try {
    const assignedCount = await (prisma as any).courseAssignment.count({
      where: { userId },
    });
    stats.assignedTrainingCount = assignedCount;
  } catch {}

  try {
    const completedCount = await (prisma as any).courseAssignment.count({
      where: {
        userId,
        progressStatus: "COMPLETED",
      },
    });
    stats.completedTrainingCount = completedCount;
  } catch {}

  try {
    const pendingJprReviews = await (prisma as any).jPREvaluationAttempt.count({
      where: {
        studentUserId: userId,
        workflowStatus: "SELF_SUBMITTED",
      },
    });
    stats.pendingJprReviews = pendingJprReviews;
  } catch {}

  try {
    const pendingDocumentSignatures = await (prisma as any).documentAcknowledgement.count({
      where: {
        userId,
        status: {
          in: ["ASSIGNED", "PENDING_SIGNATURE"],
        },
      },
    });
    stats.pendingDocumentSignatures = pendingDocumentSignatures;
  } catch {}

  return stats;
}

async function getAttentionItemsSafe(userId: string) {
  const items: Array<{
    id: string;
    title: string;
    subtitle: string;
    actionLabel: string;
    destination: string;
  }> = [];

  try {
    const nextTraining = await (prisma as any).courseAssignment.findFirst({
      where: {
        userId,
        progressStatus: {
          in: ["NOT_STARTED", "IN_PROGRESS"],
        },
      },
      orderBy: {
        createdAt: "desc",
      },
      select: {
        id: true,
        courseId: true,
        course: {
          select: {
            title: true,
          },
        },
      },
    });

    if (nextTraining) {
      items.push({
        id: "attention-training",
        title: "Training Assigned",
        subtitle: `${nextTraining.course?.title || "Assigned training"} is waiting for you.`,
        actionLabel: "Open Training",
        destination: `/members/training/${nextTraining.courseId || nextTraining.id}`,
      });
    }
  } catch {}

  try {
    const pendingDoc = await (prisma as any).documentAcknowledgement.findFirst({
      where: {
        userId,
        status: {
          in: ["ASSIGNED", "PENDING_SIGNATURE"],
        },
      },
      orderBy: {
        createdAt: "desc",
      },
      select: {
        id: true,
        documentId: true,
        document: {
          select: {
            title: true,
          },
        },
      },
    });

    if (pendingDoc) {
      items.push({
        id: `attention-document-${pendingDoc.id}`,
        title: "Document Signature Needed",
        subtitle: `${pendingDoc.document?.title || "A document"} needs your acknowledgement.`,
        actionLabel: "Open Document",
        destination: `/members/documents/${pendingDoc.documentId || pendingDoc.id}`,
      });
    }
  } catch {}

  if (!items.length) {
    items.push({
      id: "attention-fallback",
      title: "Welcome Back",
      subtitle: "Your dashboard is connected and ready for the next step.",
      actionLabel: "Open Dashboard",
      destination: "/members",
    });
  }

  return items;
}

async function getLatestUpdatesSafe(userId: string) {
  const updates: Array<{
    id: string;
    title: string;
    subtitle: string;
    createdAt: string | null;
  }> = [];

  try {
    const recentTraining = await (prisma as any).courseAssignment.findMany({
      where: { userId },
      orderBy: {
        createdAt: "desc",
      },
      take: 3,
      select: {
        id: true,
        progressStatus: true,
        createdAt: true,
        course: {
          select: {
            title: true,
          },
        },
      },
    });

    for (const item of recentTraining) {
      updates.push({
        id: `training-${item.id}`,
        title: "Training Update",
        subtitle: `${item.course?.title || "Training"} • ${item.progressStatus}`,
        createdAt: timeAgo(item.createdAt),
      });
    }
  } catch {}

  try {
    const recentDocs = await (prisma as any).documentAcknowledgement.findMany({
      where: { userId },
      orderBy: {
        createdAt: "desc",
      },
      take: 3,
      select: {
        id: true,
        status: true,
        createdAt: true,
        document: {
          select: {
            title: true,
          },
        },
      },
    });

    for (const item of recentDocs) {
      updates.push({
        id: `document-${item.id}`,
        title: "Document Update",
        subtitle: `${item.document?.title || "Document"} • ${item.status}`,
        createdAt: timeAgo(item.createdAt),
      });
    }
  } catch {}

  if (!updates.length) {
    updates.push({
      id: "latest-fallback",
      title: "System Update",
      subtitle: "Mobile dashboard route is live.",
      createdAt: "just now",
    });
  }

  return updates.slice(0, 6);
}

export async function GET(req: NextRequest) {
  try {
    const token = extractBearerToken(req.headers.get("authorization"));

    if (!token) {
      return NextResponse.json(
        { success: false, error: "Missing bearer token." },
        { status: 401 }
      );
    }

    const payload = verifyMobileToken(token);
    const userId = payload.sub;

    const [attentionItems, dashboardUpdates, latestUpdates, stats] =
      await Promise.all([
        getAttentionItemsSafe(userId),
        getDashboardUpdatesSafe(),
        getLatestUpdatesSafe(userId),
        getTrainingStatsSafe(userId),
      ]);

    return NextResponse.json({
      attentionItems,
      dashboardUpdates,
      latestUpdates,
      stats,
    });
  } catch (error) {
    console.error("GET /api/mobile/dashboard error:", error);
    return NextResponse.json(
      { success: false, error: "Unauthorized." },
      { status: 401 }
    );
  }
}